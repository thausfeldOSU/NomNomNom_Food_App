<h1>NNN Food Items</h1>

{{! READ table }}
<table>
    <thead>
        {{! For the table header row, we print the DB attribute names }}
        <tr>
            {{#each food.[0]}}
            <th>
                {{@key}}
            </th>
            {{/each}}
            <th></th>
        </tr>
    </thead>

    <tbody>
        {{! Print values for each row of data returned by the SQL statement returned from app.js }}
        {{#each food}}
        <tr>
            <td>{{this.RESTAURANT_NAME}}</td>
            <td>{{this.FOOD_ID}}</td>
            <td>{{this.FOOD_NAME}}</td>
            <td>{{this.PRICE}}</td>

            {{! DELETE form }}
            <form action='delete_food_item' method="POST">
                <input type='hidden' name='delete_food_id' value="{{this.FOOD_ID}}"/>
                <td>
                    <button type='submit'>
                        Delete
                    </button>
                </td>
            </form>
        </tr>
        {{/each}}
    </tbody>
</table>

{{! CREATE form }}
<h2>Create a New Food Item</h2>
<form action='create_food_item' method="POST">
    <label for='create_food_item_name'>Name: </label>
    <input type='text' name='create_food_item_name' id='create_food_item_name' required />

    <label for='create_food_item_price'>Price: </label>
    {{!-- Used Google AI to figure out what to was missing here to allow for decimal as expected for a currency. --}}
    <input type='number' name='create_food_item_price' id='create_food_item_price' min='0' step='0.01'/>

    <label for='create_food_item_restaurant'>Restaurant: </label>
    <select name='create_food_item_restaurant' id='create_food_item_restaurant'>
        <option value='' selected>Select a Restaurant</option>
        {{#each restaurant}}
        <option value='{{this.RESTAURANT_ID}}' required>{{this.NAME}}</option>
        {{/each}}
    </select>
    <input type='submit' />
</form>

{{! UPDATE form }}
{{! FOOD_ITEM needs the following fields in order to update: FOOD_ITEM_ID, RESTAURANT_ID, NAME (name of the food), and a PRICE }}
<h2>Update a Food Item</h2>
<form action='update_food_item' method="POST">
    <label for='update_food_item_name_id'>Food to Update: </label>
    <select name='update_food_item_name_id' id='update_food_item_name_id' required>
        <option value=''>Select a Food Item</option>
        {{#each foods}}
        <option value='{{this.FOOD_ITEM_ID}}' required>{{this.NAME}}</option>
        {{/each}}
    </select>

    <label for='update_food_item_restaurant_id'>New Restaurant: </label>
    <select name='update_food_item_restaurant_id' id='update_food_item_restaurant_id'>
        <option value='' disabled selected>Select a Restaurant</option>
        {{#each restaurant}}
        <option value='{{this.RESTAURANT_ID}}' required>
            {{this.NAME}} {{! The FOOD_ITEM table has restaurants stored as a numerical foreign key so return the ID, not the name for updating the table }}
        </option>
        {{/each}}
    </select>

    <label for='update_food_item_name'>New Food Name: </label>
    <input type='text' name='update_food_item_name' id='update_food_item_name' min='0' />

    <label for='update_food_item_price'>New Price: </label>
    {{!-- Used Google AI to figure out what to was missing here to allow for decimal as expected for a currency. --}}
    <input type='number' name='update_food_item_price' id='update_food_item_price' min='0' step='0.01'/>

    <input type='submit' />
</form>