<h1>NNN Restaurants</h1>

{{! READ table }}
<table>
    <thead>
        {{! For the table header row, we print the DB attribute names }}
        <tr>
            {{#each restaurant.[0]}}
            <th>
                {{@key}}
            </th>
            {{/each}}
            <th></th>
        </tr>
    </thead>

    <tbody>
        {{! Print values for each row of data returned by the SQL statement returned from app.js }}
        {{#each restaurant}}
        <tr>
            <td>{{this.NAME}}</td>
            <td>{{this.RATING}}</td>
            <td>{{this.PHONE_NUMBER}}</td>
            <td>{{this.ADDRESS}}</td>
            <td>{{this.EMAIL}}</td>

            {{!-- Took out from template since the delete is on Food Items and Orders pages --}}
        </tr>
        {{/each}}
    </tbody>
</table>

